# ─────────────────────────────────────────────────────
# StaffTrack PWA — Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=StaffTrack
NODE_ENV=development

# ── Database (Supabase PostgreSQL) ───────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Authentication ────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-at-least-32-chars-long
AUTH_URL=https://your-domain.com

# Session config
SESSION_MAX_AGE=86400          # 24 hours for staff (seconds)
ADMIN_SESSION_MAX_AGE=3600     # 1 hour for admin (seconds)
INACTIVITY_TIMEOUT=1800        # 30 min admin auto-logout (seconds)

# ── Redis (Upstash — rate limiting & caching) ─────────
# Get from: upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Supabase Storage (profile photos, attachments) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Web Push Notifications ────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@your-domain.com

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@your-domain.com

# ── Geocoding (for reverse geocoding GPS → address) ──
# Free tier: nominatim.openstreetmap.org (no key needed)
# Or use Google Maps: console.cloud.google.com
GEOCODING_PROVIDER=nominatim
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Security ──────────────────────────────────────────
# Rate limiting thresholds
RATE_LIMIT_LOGIN_MAX=5          # attempts per window
RATE_LIMIT_LOGIN_WINDOW=900     # 15 minutes (seconds)
RATE_LIMIT_API_MAX=100          # requests per window
RATE_LIMIT_API_WINDOW=60        # 1 minute (seconds)

# Account locking
ACCOUNT_LOCK_ATTEMPTS=5         # failed attempts before lock
ACCOUNT_LOCK_DURATION=1800      # 30 minutes (seconds)

# ── Cron / Scheduled Jobs ─────────────────────────────
# Used to sign cron requests (Vercel Cron or similar)
CRON_SECRET=your-cron-secret-key

# ── File Upload ───────────────────────────────────────
MAX_FILE_SIZE=5242880           # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf
