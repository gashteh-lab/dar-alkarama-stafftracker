generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CompanySettings {
  id                       String   @id @default(cuid())
  name                     String   @default("StaffTrack")
  logoUrl                  String?
  timezone                 String   @default("Asia/Dubai")
  workingWeekStart         Int      @default(0)
  workingWeekEnd           Int      @default(4)
  defaultGracePeriod       Int      @default(15)
  geofenceRequired         Boolean  @default(true)
  gpsAccuracyMin           Int      @default(100)
  offlinePunchAllowed      Boolean  @default(true)
  selfieRequired           Boolean  @default(false)
  correctionAllowed        Boolean  @default(true)
  managerApprovalRequired  Boolean  @default(false)
  pushNotificationsEnabled Boolean  @default(true)
  dateFormat               String   @default("DD/MM/YYYY")
  timeFormat               String   @default("12h")
  language                 String   @default("en")
  theme                    String   @default("light")
  updatedAt                DateTime @updatedAt
  updatedBy                String?
}

model User {
  id                    String              @id @default(cuid())
  email                 String?             @unique
  phone                 String?             @unique
  employeeId            String?             @unique
  passwordHash          String
  role                  Role                @default(STAFF)
  isActive              Boolean             @default(true)
  failedAttempts        Int                 @default(0)
  lockedAt              DateTime?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  attendanceEdited      AttendanceRecord[]  @relation("AttendanceEditor")
  auditLogsCreated      AuditLog[]          @relation("AuditUser")
  correctionsReviewed   CorrectionRequest[] @relation("CorrectionReviewer")
  notificationsReceived Notification[]
  passwordResets        PasswordReset[]
  pushSubscriptions     PushSubscription[]
  sessions              Session[]
  profile               StaffProfile?

  @@index([email])
  @@index([employeeId])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model Branch {
  id          String         @id @default(cuid())
  name        String
  address     String?
  timezone    String         @default("Asia/Dubai")
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  departments Department[]
  geofences   Geofence[]
  staff       StaffProfile[]

  @@map("branches")
}

model Department {
  id        String         @id @default(cuid())
  name      String
  branchId  String?
  managerId String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  branch    Branch?        @relation(fields: [branchId], references: [id])
  staff     StaffProfile[]

  @@map("departments")
}

model StaffProfile {
  id                String              @id @default(cuid())
  userId            String              @unique
  fullName          String
  photoUrl          String?
  departmentId      String?
  position          String?
  branchId          String?
  managerId         String?
  shiftId           String?
  employmentStatus  EmploymentStatus    @default(ACTIVE)
  joiningDate       DateTime?
  workingDays       String[]            @default(["MON", "TUE", "WED", "THU", "FRI"])
  punchMethod       String[]            @default(["GPS"])
  geofenceId        String?
  policyGroupId     String?
  emergencyContact  String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attendanceRecords AttendanceRecord[]
  corrections       CorrectionRequest[]
  punchEvents       PunchEvent[]
  branch            Branch?             @relation(fields: [branchId], references: [id])
  department        Department?         @relation(fields: [departmentId], references: [id])
  geofence          Geofence?           @relation(fields: [geofenceId], references: [id])
  shift             Shift?              @relation(fields: [shiftId], references: [id])
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([departmentId])
  @@index([branchId])
  @@map("staff_profiles")
}

model Shift {
  id                String             @id @default(cuid())
  name              String
  startTime         String
  endTime           String
  gracePeriod       Int                @default(15)
  breakDuration     Int                @default(60)
  workingHours      Float              @default(8)
  shiftType         ShiftType          @default(FIXED)
  crossesMidnight   Boolean            @default(false)
  color             String             @default("#1D9E75")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceRecords AttendanceRecord[]
  staff             StaffProfile[]

  @@map("shifts")
}

model Geofence {
  id           String         @id @default(cuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int            @default(200)
  branchId     String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branch       Branch?        @relation(fields: [branchId], references: [id])
  staff        StaffProfile[]

  @@map("geofences")
}

model AttendanceRecord {
  id                 String              @id @default(cuid())
  staffId            String
  date               DateTime            @db.Date
  shiftId            String?
  punchIn            DateTime?
  punchOut           DateTime?
  punchInLat         Float?
  punchInLng         Float?
  punchOutLat        Float?
  punchOutLng        Float?
  punchInAddress     String?
  punchOutAddress    String?
  punchInDevice      Json?
  punchOutDevice     Json?
  status             AttendanceStatus    @default(PRESENT)
  lateMinutes        Int                 @default(0)
  earlyLeaveMinutes  Int                 @default(0)
  overtimeMinutes    Int                 @default(0)
  totalWorkedMinutes Int                 @default(0)
  breakMinutes       Int                 @default(0)
  source             PunchSource         @default(ONLINE)
  editedBy           String?
  editReason         String?
  isFlagged          Boolean             @default(false)
  flagReason         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  editor             User?               @relation("AttendanceEditor", fields: [editedBy], references: [id])
  shift              Shift?              @relation(fields: [shiftId], references: [id])
  staff              StaffProfile        @relation(fields: [staffId], references: [id])
  corrections        CorrectionRequest[]
  punchEvents        PunchEvent[]

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
  @@index([status])
  @@map("attendance_records")
}

model PunchEvent {
  id         String            @id @default(cuid())
  recordId   String?
  staffId    String
  type       String
  timestamp  DateTime
  lat        Float?
  lng        Float?
  address    String?
  accuracy   Float?
  deviceInfo Json?
  ipAddress  String?
  source     PunchSource       @default(ONLINE)
  isSynced   Boolean           @default(true)
  syncedAt   DateTime?
  createdAt  DateTime          @default(now())
  record     AttendanceRecord? @relation(fields: [recordId], references: [id])
  staff      StaffProfile      @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([timestamp])
  @@map("punch_events")
}

model OfflineSyncQueue {
  id              String    @id @default(cuid())
  staffId         String
  eventType       String
  payload         Json
  deviceTimestamp DateTime
  isSynced        Boolean   @default(false)
  syncAttempts    Int       @default(0)
  syncedAt        DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([staffId, isSynced])
  @@map("offline_sync_queue")
}

model CorrectionRequest {
  id              String            @id @default(cuid())
  staffId         String
  recordId        String?
  date            DateTime          @db.Date
  requestType     CorrectionType
  correctPunchIn  DateTime?
  correctPunchOut DateTime?
  reason          String
  attachmentUrl   String?
  status          CorrectionStatus  @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewComment   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  record          AttendanceRecord? @relation(fields: [recordId], references: [id])
  reviewer        User?             @relation("CorrectionReviewer", fields: [reviewedBy], references: [id])
  staff           StaffProfile      @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([status])
  @@map("correction_requests")
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @db.Date
  isRecurring Boolean  @default(false)
  branchId    String?
  createdAt   DateTime @default(now())

  @@index([date])
  @@map("holidays")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  deviceInfo Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  reason    String?
  ipAddress String?
  userAgent String?
  timestamp DateTime    @default(now())
  user      User?       @relation("AuditUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  EARLY_LEAVE
  OVERTIME
  MISSED_PUNCH_OUT
  PENDING_CORRECTION
  OUTSIDE_GEOFENCE
  OFFLINE_PUNCH
  MANUAL_ADJUSTMENT
  WEEKEND
  HOLIDAY
  ON_LEAVE
}

enum PunchSource {
  ONLINE
  OFFLINE
  MANUAL
}

enum ShiftType {
  FIXED
  FLEXIBLE
  ROTATING
  SPLIT
  NIGHT
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CorrectionType {
  FORGOT_PUNCH_IN
  FORGOT_PUNCH_OUT
  WRONG_LOCATION
  TECHNICAL_ISSUE
  SHIFT_ISSUE
  APPROVED_LEAVE
  OTHER
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PUNCH_IN
  PUNCH_OUT
  PUNCH_FAILED
  LOCATION_REJECTED
  GEOFENCE_VIOLATION
  STAFF_CREATED
  STAFF_UPDATED
  STAFF_DEACTIVATED
  ATTENDANCE_EDITED
  SHIFT_ASSIGNED
  CORRECTION_SUBMITTED
  CORRECTION_APPROVED
  CORRECTION_REJECTED
  EXPORT_GENERATED
  SETTINGS_CHANGED
  PASSWORD_RESET
  ACCOUNT_LOCKED
  OFFLINE_SYNC
}

enum NotificationType {
  PUNCH_REMINDER
  LATE_WARNING
  ABSENT_ALERT
  MISSED_PUNCH_OUT
  CORRECTION_STATUS
  GEOFENCE_EXCEPTION
  ANNOUNCEMENT
  OFFLINE_SYNCED
}
